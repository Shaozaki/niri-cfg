layout {

    focus-ring {
        active-color   "#cabeff"
        inactive-color "#141316"
        urgent-color   "#ffb4ab"
    }

    border {
        active-color   "#cabeff"
        inactive-color "#141316"
        urgent-color   "#ffb4ab"
    }

    shadow {
        color "#00000070"
    }

    tab-indicator {
        active-color   "#cabeff"
        inactive-color "#48398d"
        urgent-color   "#ffb4ab"
    }

    insert-hint {
        color "#cabeff80"
    }
}

recent-windows {
    highlight {
        active-color "#cabeff"
        urgent-color "#ffb4ab"
    }
}
